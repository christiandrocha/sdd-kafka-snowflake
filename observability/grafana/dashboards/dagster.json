{
  "id": null,
  "uid": "dagster-overview",
  "title": "Dagster \u2014 Pipeline Throughput",
  "tags": [
    "dagster",
    "dbt"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Messages In \u2014 CDC Topics (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(kafka_server_brokertopicmetrics_messagesin{topic=~\"pg\\.public\\..+\"}[1m]) * 60",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Lag Total \u2014 sink",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"connect-sink\"})",
          "legendFormat": "sink",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Lag Total \u2014 sinkitems",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"connect-sinkitems\"})",
          "legendFormat": "sinkitems",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000
              },
              {
                "color": "red",
                "value": 50000
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Bytes In \u2014 Top 5 CDC Topics",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(5, rate(kafka_server_brokertopicmetrics_bytesin{topic=~\"pg\\.public\\..+\"}[1m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": []
}