{
  "id": null,
  "uid": "kafka-connect-overview",
  "title": "Kafka Connect \u2014 CDC Pipeline Health",
  "tags": [
    "kafka-connect",
    "debezium",
    "snowflake"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Consumer Lag \u2014 sink (19 topics)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag{consumergroup=\"connect-sink\",topic=~\"pg\\.public\\..+\"}",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Consumer Lag \u2014 sinkitems (order_items)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag{consumergroup=\"connect-sinkitems\"}",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 3,
      "title": "Total Lag \u2014 all connect groups",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=~\"connect-.+\",topic=~\"pg\\.public\\..+\"})",
          "legendFormat": "Total lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 10000
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Request Rate (Produce/Fetch)",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 9,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(kafka_network_requestmetrics_requestspersec[1m])",
          "legendFormat": "{{request}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 5,
      "title": "Log Size \u2014 CDC Topics (bytes)",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 9,
        "x": 15,
        "y": 8
      },
      "targets": [
        {
          "expr": "kafka_log_size_bytes{topic=~\"pg\\.public\\..+\"}",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "links": []
}