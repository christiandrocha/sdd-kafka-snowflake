{
  "id": null,
  "uid": "kafka-connect-overview",
  "title": "Kafka Connect — Connector Status",
  "tags": ["kafka-connect", "debezium", "snowflake"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Connector Status",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "kafka_connect_connector_task_status",
          "legendFormat": "{{connector}} / task {{task}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (Produce/Fetch)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(kafka_network_requestmetrics_requestspersec[1m])",
          "legendFormat": "{{request}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Log Size by Topic (bytes)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "kafka_log_size_bytes",
          "legendFormat": "{{topic}} / {{partition}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []},
  "links": []
}
