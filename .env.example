# .env.example
# Copy to .env and fill in real values before running docker compose.
# This file is safe to commit. .env is gitignored.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=poc_user
POSTGRES_PASSWORD=poc_pass123
POSTGRES_DB=pocdb
DATABASE_URL=ppostgresql://poc_user:poc_pass123@localhost:5432/pocdb

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_URL=dummy.snowflakecomputing.com
SNOWFLAKE_ACCOUNT=dummy
SNOWFLAKE_USER=dummy
SNOWFLAKE_PRIVATE_KEY=dummy
SNOWFLAKE_PRIVATE_KEY_PATH=/secrets/snowflake_private_key.pem
SNOWFLAKE_DATABASE=CDC_POC
SNOWFLAKE_WAREHOUSE=CDC_WH
SNOWFLAKE_ROLE=CDC_ROLE

# ── Schema Registry ────────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_TARGET=dev
